# ====== 基础配置 ======
DATABASE_URL="file:./dev.db"
AUTH_SECRET="请替换为随机密钥-change-me-to-random-string"

# 访问地址（部署时改为你的正式域名，如 https://quote.shitianuav.com）
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"

# ====== 阿里云 OSS（图片/文件存储）======
OSS_REGION="oss-ap-southeast-1"
OSS_BUCKET="shitian-quete1-assets"
OSS_ACCESS_KEY_ID="你的AccessKeyID"
OSS_ACCESS_KEY_SECRET="你的AccessKeySecret"
OSS_CDN_DOMAIN="cdn-quote.shitianuav.com"

# ====== 阿里百炼 AI 助手（可选）======
DASHSCOPE_API_KEY="你的百炼API密钥"
DASHSCOPE_APP_ID="你的百炼应用ID"
