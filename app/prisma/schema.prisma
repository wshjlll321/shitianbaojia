generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String             @id @default(cuid())
  model       String             @unique
  nameZh      String
  nameEn      String
  nameTh      String             @default("")
  category    String
  imageUrl    String             @default("")
  featuresZh  String             @default("[]")
  featuresEn  String             @default("[]")
  featuresTh  String             @default("[]")
  specsZh     String             @default("{}")
  specsEn     String             @default("{}")
  specsTh     String             @default("{}")
  msrp        Float              @default(0)
  exwPrice    Float              @default(0)
  fobPrice    Float              @default(0)
  isActive    Boolean            @default(true)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  accessoryOf ProductAccessory[] @relation("Accessory")
  accessories ProductAccessory[] @relation("MainProduct")
  quoteItems  QuoteItem[]
  skus        SKU[]
}

model SKU {
  id         String      @id @default(cuid())
  productId  String
  name       String
  nameEn     String      @default("")
  nameTh     String      @default("")
  labelZh    String      @default("")
  labelEn    String      @default("")
  sku        String      @unique
  price      Float
  descZh     String      @default("")
  descEn     String      @default("")
  descTh     String      @default("")
  includesZh String      @default("[]")
  includesEn String      @default("[]")
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  quoteItems QuoteItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductAccessory {
  id            String  @id @default(cuid())
  mainProductId String
  accessoryId   String
  isRecommended Boolean @default(false)
  accessory     Product @relation("Accessory", fields: [accessoryId], references: [id], onDelete: Cascade)
  mainProduct   Product @relation("MainProduct", fields: [mainProductId], references: [id], onDelete: Cascade)

  @@unique([mainProductId, accessoryId])
}

model User {
  id          String       @id @default(cuid())
  username    String?      @unique
  email       String?      @unique
  password    String
  nameZh      String
  nameEn      String       @default("")
  phone       String       @default("")
  wechatQr    String       @default("")
  avatarUrl   String       @default("")
  role        String       @default("sales")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  inviteCodes InviteCode[]
  quotes      Quote[]
}

model Quote {
  id             String        @id @default(cuid())
  quoteNumber    String        @unique
  clientName     String
  clientContact  String        @default("")
  clientEmail    String        @default("")
  titleZh        String
  titleEn        String        @default("")
  titleTh        String        @default("")
  quoteDate      DateTime      @default(now())
  validUntil     DateTime
  currency       String        @default("CNY")
  deliveryTerms  String        @default("FOB Qingdao")
  warrantyZh     String        @default("整机质保1年")
  warrantyEn     String        @default("1-year full warranty")
  paymentTermsZh String        @default("预付70%，发货前付清30%")
  paymentTermsEn String        @default("70% advance, 30% before shipment")
  deliveryTimeZh String        @default("合同签订后45个工作日内")
  deliveryTimeEn String        @default("Within 45 business days after contract signed")
  trainingZh     String        @default("含5天免费操作培训")
  trainingEn     String        @default("5-day free operation training included")
  termsJson      String        @default("[]")
  subtotal       Float         @default(0)
  discount       Float         @default(0)
  totalPrice     Float         @default(0)
  shareTokenHash String?       @unique
  shareToken     String?       @unique
  tokenExpiresAt DateTime
  status         String        @default("draft")
  salesId        String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  inviteCode     InviteCode?
  sales          User          @relation(fields: [salesId], references: [id])
  items          QuoteItem[]
  trackingLogs   TrackingLog[]
}

model QuoteItem {
  id                    String   @id @default(cuid())
  quoteId               String
  productId             String
  skuId                 String?
  skuName               String   @default("")
  nameZh                String
  nameEn                String   @default("")
  nameTh                String   @default("")
  snapshotModel         String   @default("")
  snapshotImageUrl      String   @default("")
  snapshotFeaturesZh    String   @default("[]")
  snapshotFeaturesEn    String   @default("[]")
  snapshotSpecsZh       String   @default("{}")
  snapshotSpecsEn       String   @default("{}")
  snapshotSkuIncludesZh String   @default("[]")
  snapshotSkuIncludesEn String   @default("[]")
  unitPrice             Float
  quantity              Int      @default(1)
  totalPrice            Float
  sortOrder             Int      @default(0)
  isMainItem            Boolean  @default(false)
  remark                String   @default("")
  createdAt             DateTime @default(now())
  sku                   SKU?     @relation(fields: [skuId], references: [id])
  product               Product  @relation(fields: [productId], references: [id])
  quote                 Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model InviteCode {
  id            String    @id @default(cuid())
  code          String    @unique
  clientName    String
  clientContact String    @default("")
  clientEmail   String    @default("")
  currency      String    @default("USD")
  deliveryTerms String    @default("FOB Qingdao")
  validDays     Int       @default(30)
  discount      Float     @default(0)
  remark        String    @default("")
  status        String    @default("pending")
  expiresAt     DateTime
  usedAt        DateTime?
  aiSessionId   String?
  aiMessages    String    @default("[]")
  quoteId       String?   @unique
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     User      @relation(fields: [createdById], references: [id])
  quote         Quote?    @relation(fields: [quoteId], references: [id])
}

model TrackingLog {
  id        String   @id @default(cuid())
  quoteId   String
  event     String
  visitorIp String   @default("")
  userAgent String   @default("")
  duration  Int      @default(0)
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}
